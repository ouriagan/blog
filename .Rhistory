#| label: fig-cadre-loi
#| fig-cap: "Répartition des situations par rapport au cadre de la loi (Anne-Françoise Dahin)."
#| echo: false
#| message: false
#| warning: false
library(ggplot2)
library(grid)
# Points noirs à l'intérieur du cadre interne
inside <- data.frame(
x = c(5, 6, 7, 4, 5, 7),
y = c(5, 5, 5, 4, 4, 3)
)
# Points noirs à l'extérieur
outside <- data.frame(
x = c(1.8, 1.6, 2.0, 1.8, 2.0, 4.9),
y = c(6.2, 4.8, 2.8, 1.9, 3.4, 1.7)
)
# Croix noires sur le bord gauche
crosses_black <- data.frame(
x = c(1, 1, 1, 1, 1),
y = c(6, 5, 4, 3, 2)
)
# Croix grise
cross_grey <- data.frame(
x = 1.95,
y = 5.45
)
p <- ggplot() +
# Grand cadre
geom_rect(aes(xmin = 1, xmax = 9, ymin = 1, ymax = 7),
fill = "grey92", color = "black", linewidth = 0.8) +
# Cadre interne
geom_rect(aes(xmin = 2.9, xmax = 7.5, ymin = 2.7, ymax = 5.8),
fill = "white", color = "black", linewidth = 0.8) +
# Titre
annotate("text", x = 6, y = 6.45, label = "Cadre de la loi", size = 30/.pt) +
# Points
geom_point(data = inside, aes(x, y), size = 3.5, color = "black") +
geom_point(data = outside, aes(x, y), size = 3.5, color = "black") +
# Croix noires à gauche
geom_point(data = crosses_black, aes(x, y), shape = 4, stroke = 2.5, size = 6, color = "black") +
# Croix grise
geom_point(data = cross_grey, aes(x, y), shape = 4, stroke = 3, size = 7, color = "grey55") +
# Flèche oblique haute
annotate("segment",
x = 5, y = 5,
xend = 2, yend = 6.1,
linewidth = 0.7,
arrow = arrow(length = unit(0.18, "cm"))) +
# Flèche oblique basse
annotate("segment",
x = 7, y = 3,
xend = 2.15, yend = 2.8,
linewidth = 0.7,
arrow = arrow(length = unit(0.18, "cm"))) +
# Flèche courbe à droite
annotate("curve",
x = 7.7, y = 6.1,
xend = 7.7, yend = 4.9,
curvature = -0.6,
linewidth = 1.2,
arrow = arrow(length = unit(0.22, "cm"))) +
coord_fixed(xlim = c(0.8, 9.2), ylim = c(1, 7.1), expand = FALSE) +
theme_void()
p
print(p)
